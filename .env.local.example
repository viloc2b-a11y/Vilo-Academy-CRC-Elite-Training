# Public (browser) — safe to expose with NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: n8n → Next.js webhook HMAC (generate a long random string)
N8N_WEBHOOK_SECRET=change-me-to-a-long-random-secret

# Server-only: Supabase service role for trusted webhook writes (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
